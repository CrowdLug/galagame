root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cpp,h,hpp,cxx,hxx,inl}]
indent_style = space
indent_size = 4

[CMakeLists.txt]
indent_style = space
indent_size = 2

[*.cmake]
indent_style = space
indent_size = 2

[*.{json,md,yml,yaml}]
indent_style = space
indent_size = 2

[*.cmd]
end_of_line = crlf
charset = utf-8

[*.ps1]
end_of_line = crlf
charset = utf-8

